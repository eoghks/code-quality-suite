<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  [시나리오 테스트] Security Agent 검증 대상

  포함된 의도적 위반:
   - SQL ${} 직접 치환 (A03 — SQL Injection) [Critical]
   - 주석 화이트리스트 없는 ${} 사용 [Critical]
-->
<mapper namespace="com.example.mapper.UserMapper">

    <!-- ❌ Critical — SQL Injection: ${name} 직접 치환 -->
    <select id="findByName" resultType="User">
        SELECT * FROM user WHERE name = '${name}'
    </select>

    <!-- ❌ Critical — 동적 정렬 컬럼에 주석 없이 ${} 사용 -->
    <select id="findAllSorted" resultType="User">
        SELECT * FROM user ORDER BY ${sortColumn}
    </select>

    <!-- ❌ Critical — WHERE 조건에 ${} 직접 치환 -->
    <select id="search" resultType="User">
        SELECT * FROM user WHERE ${condition}
    </select>

    <!-- ✅ 올바른 파라미터 바인딩 -->
    <select id="findById" resultType="User">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <!-- ✅ 화이트리스트 주석 명시 시 허용 -->
    <!-- sortColumn: Controller 화이트리스트 검증 완료 (CREATED_AT, NAME 만 허용) -->
    <select id="findAllSortedSafe" resultType="User">
        SELECT * FROM user ORDER BY ${sortColumn}
    </select>

</mapper>
